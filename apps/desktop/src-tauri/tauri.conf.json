{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Yapper",
  "version": "0.4.0",
  "identifier": "com.yapper.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Yapper",
        "width": 440,
        "height": 630,
        "center": true,
        "resizable": true,
        "minWidth": 440,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "widget",
        "title": "",
        "url": "/widget.html",
        "width": 280,
        "height": 110,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "infoPlist": "./Info.plist",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowPosition": {
          "x": 200,
          "y": 200
        },
        "windowSize": {
          "width": 540,
          "height": 500
        },
        "appPosition": {
          "x": 270,
          "y": 100
        },
        "applicationFolderPosition": {
          "x": 270,
          "y": 350
        }
      }
    }
  }
}
