{
  "name": "yapper-bridge",
  "displayName": "Yapper Bridge",
  "description": "Local WebSocket bridge between Yapper desktop app and GitHub Copilot",
  "version": "0.0.3",
  "publisher": "yapper",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptRefinement.startBridge",
        "title": "Start Yapper Bridge"
      },
      {
        "command": "promptRefinement.stopBridge",
        "title": "Stop Yapper Bridge"
      },
      {
        "command": "promptRefinement.showStatus",
        "title": "Show Yapper Bridge Status"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepackage": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.5",
    "@vscode/vsce": "^3"
  }
}
