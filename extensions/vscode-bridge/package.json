{
  "name": "yapper-bridge",
  "displayName": "Yapper Bridge",
  "description": "Local WebSocket bridge between Yapper desktop app and GitHub Copilot",
  "version": "0.0.9",
  "publisher": "yapper",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Yapper",
      "properties": {
        "yapper.modelFamily": {
          "type": "string",
          "default": "gemini-2.0-flash",
          "enum": ["gemini-2.0-flash", "gemini-2.5-pro", "claude-sonnet-4", "claude-haiku-4", "gpt-4o-mini", "gpt-4o"],
          "enumDescriptions": [
            "Gemini 2.0 Flash — fast and free",
            "Gemini 2.5 Pro — higher quality",
            "Claude Sonnet 4 — great balance of speed and quality",
            "Claude Haiku 4 — fastest Claude model",
            "GPT-4o Mini — fast Copilot model",
            "GPT-4o — more nuanced, slightly slower"
          ],
          "description": "Preferred model family for transcript refinement (works with Gemini, Claude, or Copilot)"
        },
        "yapper.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key — free, fast, no credit card (https://console.groq.com/keys)"
        },
        "yapper.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key (https://aistudio.google.com/apikey)"
        },
        "yapper.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key"
        }
      }
    },
    "commands": [
      {
        "command": "promptRefinement.startBridge",
        "title": "Start Yapper Bridge"
      },
      {
        "command": "promptRefinement.stopBridge",
        "title": "Stop Yapper Bridge"
      },
      {
        "command": "promptRefinement.showStatus",
        "title": "Show Yapper Bridge Status"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./ && node esbuild.config.mjs",
    "watch": "tsc -watch -p ./",
    "prepackage": "npm run compile && rm -f out/*.map",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.12",
    "@vscode/vsce": "^3",
    "esbuild": "^0.27.4",
    "typescript": "^5.5"
  }
}
